{
      "name": "@aromix/sqlite",
      "version": "0.1.0",
      "description": "SQLite DDL & DML fluent chain API for Aromix",
      "type": "module",
      "license": "MIT",
      "homepage": "https://aromixjs.github.io/aromix",
      "repository": {
            "type": "git",
            "url": "https://github.com/aromixjs/aromix.git",
            "directory": "packages/sqlite"
      },
      "bugs": {
            "url": "https://github.com/aromixjs/aromix/issues"
      },
      "keywords": [
            "aromix",
            "sqlite",
            "ddl",
            "dml",
            "fluent"
      ],
      "files": [
            "dist"
      ],
      "exports": {
            ".": {
                  "types": "./dist/index.d.ts",
                  "import": "./dist/index.js"
            }
      },
      "publishConfig": {
            "access": "public",
            "registry": "https://registry.npmjs.org"
      },
      "scripts": {
            "build": "tsup",
            "dev": "tsup --watch",
            "typecheck": "tsc --noEmit"
      },
      "devDependencies": {
            "@aromix/core": "workspace:^",
            "@types/node": "catalog:",
            "tsup": "catalog:",
            "typescript": "catalog:"
      }
}
