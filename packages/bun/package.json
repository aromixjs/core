{
  "name": "@aromix/bun",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --no-sourcemap && tsc --emitDeclarationOnly",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@aromix/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "typescript": "^5.7.2"
  }
}
