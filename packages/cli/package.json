{
  "name": "@aromix/cli",
  "version": "0.1.1",
  "description": "CLI for Aromix",
  "type": "module",
  "license": "MIT",
  "homepage": "https://aromixjs.github.io/aromix",
  "repository": {
    "type": "git",
    "url": "https://github.com/aromixjs/aromix.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/aromixjs/aromix/issues"
  },
  "keywords": [
    "aromix",
    "cli",
    "framework",
    "tooling"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "aromix": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/bin.d.ts",
      "import": "./dist/bin.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "link": "pnpm build && pnpm add --global .",
    "unlink": "pnpm remove --global @aromix/cli"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}