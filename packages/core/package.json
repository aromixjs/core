{
  "name": "@aromix/core",
  "version": "0.2.0",
  "description": "Core runtime-agnostic framework for Aromix",
  "type": "module",
  "license": "MIT",
  "homepage": "https://aromixjs.github.io/aromix",
  "repository": {
    "type": "git",
    "url": "https://github.com/aromixjs/aromix.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/aromixjs/aromix/issues"
  },
  "keywords": [
    "aromix",
    "core",
    "server",
    "framework",
    "runtime-agnostic",
    "bun",
    "deno",
    "cloudflare",
    "node"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@msgpack/msgpack": "catalog:",
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
