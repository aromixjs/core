{
  "name": "aromix-vscode",
  "displayName": "Aromix",
  "description": "Aromix TypeScript Language Service Support",
  "version": "0.0.1",
  "publisher": "aromix",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "main": "./extension.js",
  "contributes": {
    "typescriptServerPlugins": [
      {
        "name": "@aromix/ts-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ]
  },
  "extensionDependencies": [
    "vscode.typescript-language-features"
  ],
  "dependencies": {
    "@aromix/ts-plugin": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0"
  }
}