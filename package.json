{
	"name": "@aromix/root",
	"private": true,
	"type": "module",
	"license": "MIT",
	"homepage": "https://aromixjs.github.io/aromix",
	"repository": {
		"type": "git",
		"url": "https://github.com/aromixjs/aromix.git"
	},
	"bugs": {
		"url": "https://github.com/aromixjs/aromix/issues"
	},
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"build:all": "pnpm -r build",
		"dev:all": "pnpm -r dev",
		"typecheck:all": "tsc --build",
		"format:all": "biome format --write .",
		"clean": "rimraf node_modules packages/*/node_modules packages/*/dist",
		"test:all": "vitest run",
		"change": "beachball change",
		"bump": "beachball bump",
		"release": "beachball publish --yes --access public",
		"cli:link": "pnpm --filter @aromix/cli run link",
		"cli:unlink": "pnpm --filter @aromix/cli run unlink"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"beachball": "^2.65.5",
		"@biomejs/biome": "^1.9.4",
		"rimraf": "^6.1.3",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vitest": "^4.1.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild", "@biomejs/biome"]
	}
}
