{
      "name": "@aromix/root",
      "private": true,
      "type": "module",
      "license": "MIT",
      "homepage": "https://aromixjs.github.io/aromix",
      "repository": {
            "type": "git",
            "url": "https://github.com/aromixjs/aromix.git"
      },
      "bugs": {
            "url": "https://github.com/aromixjs/aromix/issues"
      },
      "packageManager": "pnpm@11.1.2",
      "scripts": {
            "i:all": "pnpm -r install",
            "build": "pnpm -r build",
            "dev": "pnpm -r dev",
            "typecheck": "tsc --build",
            "clean": "pnpm -r exec rm -rf dist",
            "test": "vitest run",
            "test:watch": "vitest",
            "core:build": "pnpm --filter @aromix/core build",
            "core:dev": "pnpm --filter @aromix/core dev",
            "core:test": "vitest run --dir packages/core",
            "bun:build": "pnpm --filter @aromix/bun build",
            "bun:dev": "pnpm --filter @aromix/bun dev",
            "cloudflare:build": "pnpm --filter @aromix/cloudflare build",
            "cloudflare:dev": "pnpm --filter @aromix/cloudflare dev",
            "cli:build": "pnpm --filter @aromix/cli build",
            "cli:dev": "pnpm --filter @aromix/cli dev",
            "cli:link": "cd packages/cli && pnpm link --global",
            "playground:build": "pnpm --filter playground build",
            "playground:dev": "pnpm --filter playground dev",
            "format": "prettier --write .",
            "change": "beachball change",
            "bump": "beachball bump",
            "release": "beachball publish --yes --access public"
      },
      "devDependencies": {
            "@types/node": "catalog:",
            "beachball": "^2.65.5",
            "prettier": "^3.8.3",
            "tsup": "catalog:",
            "typescript": "catalog:",
            "vitest": "^4.1.6"
      },
      "pnpm": {
            "onlyBuiltDependencies": [
                  "esbuild"
            ]
      }
}
