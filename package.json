{
  "name": "@aromix/root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "core:build": "pnpm --filter @aromix/core build",
    "core:dev": "pnpm --filter @aromix/core dev",
    "node:build": "pnpm --filter @aromix/node build",
    "node:dev": "pnpm --filter @aromix/node dev",
    "basic-api:dev": "pnpm --filter @aromix/basic-api dev",
    "enterprise-api:dev": "pnpm --filter @aromix/enterprise-api dev",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "catalog:",
    "tsup": "catalog:"
  },
  "packageManager": "pnpm@10.18.0"
}
