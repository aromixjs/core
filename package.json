{
  "name": "@aromix/root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "core:build": "pnpm --filter @aromix/core build",
    "core:dev": "pnpm --filter @aromix/core dev",
    "node:build": "pnpm --filter @aromix/node build",
    "node:dev": "pnpm --filter @aromix/node dev",
    "client:build": "pnpm --filter @aromix/client build",
    "client:dev": "pnpm --filter @aromix/client dev",
    "cli:build": "pnpm --filter @aromix/cli build",
    "cli:dev": "pnpm --filter @aromix/cli dev",
    "basic:dev": "pnpm --filter @aromix/basic dev",
    "basic:build": "pnpm --filter @aromix/basic build",
    "enterprise:dev": "pnpm --filter @aromix/enterprise dev",
    "enterprise:build": "pnpm --filter @aromix/enterprise build",
    "typecheck": "pnpm -r typecheck",
    "clean": "rimraf --glob **/node_modules **/dist",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.18.0"
}
