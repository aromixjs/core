{
  "name": "@aromix/root",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "core:build": "bun run --filter @aromix/core build",
    "core:dev": "bun run --filter @aromix/core dev",
    "bun:build": "bun run --filter @aromix/bun build",
    "bun:dev": "bun run --filter @aromix/bun dev",
    "mongo:build": "bun run --filter @aromix/mongo build",
    "mongo:dev": "bun run --filter @aromix/mongo dev",
    "basic:dev": "bun run --filter @aromix/basic dev",
    "basic:build": "bun run --filter @aromix/basic build",
    "enterprise:dev": "bun run --filter @aromix/enterprise dev",
    "enterprise:build": "bun run --filter @aromix/enterprise build",
    "typecheck": "bun run --filter '*' typecheck",
    "clean": "rm -rf **/node_modules **/dist",
    "format": "bun fmt"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "typescript": "^5.7.2"
  }
}
