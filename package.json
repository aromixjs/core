{
	"name": "@aromix/core",
	"version": "0.4.7",
	"description": "The Core Package For Aromix",
	"type": "module",
	"license": "MIT",
	"homepage": "https://aromixjs.github.io/aromix",
	"repository": {
		"type": "git",
		"url": "https://github.com/aromixjs/aromix.git",
		"directory": "packages/core"
	},
	"bugs": {
		"url": "https://github.com/aromixjs/aromix/issues"
	},
	"keywords": ["aromix", "core", "server", "framework", "node", "rpc"],
	"files": ["dist"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"test": "vitest run",
		"change": "beachball change",
		"bump": "beachball bump",
		"release": "beachball publish --yes --access public"
	},
	"peerDependencies": {
		"@aromix/validator": "0.5.5",
		"mongodb": "^7.3.0",
		"redis": "^6.0.1"
	},
	"devDependencies": {
		"@aromix/validator": "0.5.5",
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.10.2",
		"beachball": "^2.65.5",
		"mongodb": "^7.3.0",
		"redis": "^6.0.1",
		"rimraf": "^6.1.3",
		"tsup": "^8.3.5",
		"typescript": "^5.7.2",
		"vitest": "^4.1.6"
	},
	"peerDependenciesMeta": {
		"mongodb": {
			"optional": true
		},
		"redis": {
			"optional": true
		}
	}
}
