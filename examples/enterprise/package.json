{
  "name": "@aromix/enterprise",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --no-sourcemap",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aromix/core": "workspace:*",
    "@aromix/bun": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "typescript": "^5.7.2"
  }
}
